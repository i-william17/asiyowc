{
  "expo": {
    "name": "Asiyo Women Connect",
    "slug": "asiyowc",
    "scheme": "asiyowc",
    "version": "1.0.0",

    "runtimeVersion": {
      "policy": "appVersion"
    },

    "orientation": "portrait",
    "icon": "./assets/images/asiyo-nobg.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "jsEngine": "hermes",

    "assetBundlePatterns": [
      "**/*"
    ],

    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },

    "experiments": {
      "turboModules": true,
      "typedRoutes": true
    },

    "splash": {
      "image": "./assets/images/asiyo-nobg.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "notification": {
      "icon": "./assets/images/notification_icon.png",
      "color": "#6A1B9A"
    },

    "ios": {
      "buildNumber": "1",
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.asiyowc",

      "associatedDomains": [
        "applinks:www.asiyoconnect.com",
        "applinks:asiyoconnect.com"
      ],

      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app needs microphone access for voice rooms.",
        "NSCameraUsageDescription": "This app uses the camera to upload profile photos and media.",
        "NSPhotoLibraryUsageDescription": "This app accesses your photo library to upload images.",
        "UIBackgroundModes": ["audio"]
      }
    },

    "android": {
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.asiyowc",

      "adaptiveIcon": {
        "foregroundImage": "./assets/images/asiyo-nobg.png",
        "backgroundColor": "#ffffff"
      },

      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "INTERNET",
        "BLUETOOTH",
        "BLUETOOTH_CONNECT"
      ],

      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE"
      ],

      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.asiyoconnect.com"
            },
            {
              "scheme": "https",
              "host": "asiyoconnect.com"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },

    "web": {
      "name": "Asiyo Women Connect",
      "favicon": "./assets/images/asiyo-nobg.png"
    },

    "plugins": [
      "expo-router",
      "expo-font",
      "react-native-compressor",
      "react-native-video",
      "expo-video",
      "@react-native-community/datetimepicker"
    ],

    "extra": {
      "router": {},
      "eas": {
        "projectId": "bc56a75f-6b8a-4619-8118-6199e886c21b"
      }
    },

    "owner": "williamwritescode"
  }
}